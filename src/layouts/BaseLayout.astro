---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "William Lunsford — Game Developer" } = Astro.props;
const pageTitle = title === "William Lunsford" ? title : `${title} — William Lunsford`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <nav>
          <a class="brand" href="/">William Lunsford</a>
          <div class="links">
            <a href="/projects">Projects</a>
            <a href="/blog">Blog</a>
            <a href="/about">About</a>
            <a href="/resume">Resume</a>
            <a href="/contact">Contact</a>
          </div>
        </nav>
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container">
        <p>&copy; {new Date().getFullYear()} William Lunsford. Built with Astro.</p>
      </div>
    </footer>
  </body>
</html>
