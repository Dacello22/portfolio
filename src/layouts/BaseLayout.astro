---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import { SITE_TITLE, SITE_DESCRIPTION, SITE_URL, AUTHOR, ROLE, SOCIALS } from "../consts";

interface Props {
  title: string;
  description?: string;
  image?: string;
  noScroll?: boolean;
}

const { title, description = SITE_DESCRIPTION, image, noScroll = false } = Astro.props;
const pageTitle = title === SITE_TITLE ? title : `${title} | ${SITE_TITLE}`;
const canonicalURL = new URL(Astro.url.pathname, SITE_URL).toString();
const imageURL = image ? new URL(image, SITE_URL).toString() : undefined;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: AUTHOR,
  jobTitle: ROLE,
  url: SITE_URL,
  sameAs: SOCIALS.filter((s) => s.href.startsWith("http")).map((s) => s.href),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title={SITE_TITLE} href="/rss.xml" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    {imageURL && <meta property="og:image" content={imageURL} />}
    <meta name="twitter:card" content={imageURL ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    {imageURL && <meta name="twitter:image" content={imageURL} />}

    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
    <ClientRouter />
  </head>
  <body class:list={[{ "no-scroll": noScroll }]}>
    <svg style="position: absolute; width: 0; height: 0; overflow: hidden" aria-hidden="true">
      <defs>
        <symbol id="cyber-star" viewBox="0 0 24 24">
          <path d="M22,12 13.556,13.556 12,22 10.444,13.556 2,12 10.444,10.444 12,2 13.556,10.444Z" />
        </symbol>
      </defs>
    </svg>
    <header class="site-header">
      <div class="container">
        <nav>
          <a class="brand" href="/">{SITE_TITLE}</a>
          <div class="links">
            <a href="/blog">Blog</a>
            <a href="/about">About</a>
            <a href="/resume">Resume</a>
            <a href="/contact">Contact</a>
          </div>
        </nav>
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
    <div id="page-rise-overlay" class="page-rise-overlay" transition:persist aria-hidden="true"></div>
  </body>
</html>

<script>
  // These must match the durations in the .page-rise-overlay CSS rules.
  const RISE_MS = 500;
  const HOLD_MS = 150;
  const FADE_MS = 400;

  function revealAfterRise() {
    const overlay = document.getElementById("page-rise-overlay");
    if (!overlay || !overlay.classList.contains("open")) return;

    // The rise animation started on the PREVIOUS page when the link was
    // clicked, not now — astro:page-load can fire well before that 500ms
    // is up (client-side nav is fast). Wait out whatever's left of the
    // rise before starting the fade, so the cover never gets interrupted
    // mid-slide.
    const openedAt = Number(overlay.dataset.openedAt || 0);
    const elapsed = openedAt ? Date.now() - openedAt : RISE_MS;
    const remaining = Math.max(0, RISE_MS - elapsed) + HOLD_MS;

    setTimeout(() => {
      overlay.classList.add("fade-out");
      setTimeout(() => {
        // Reset with transitions disabled: removing "fade-out" also
        // removes its opacity transition, so without this the opacity
        // snaps back to 1 instantly while the transform is still
        // animating back off-screen — a visible black flash. Disabling
        // transitions makes both properties reset in the same frame,
        // while already fully transparent, so nothing flashes.
        overlay.classList.add("no-transition");
        overlay.classList.remove("open", "fade-out");
        delete overlay.dataset.openedAt;
        requestAnimationFrame(() => {
          requestAnimationFrame(() => overlay.classList.remove("no-transition"));
        });
      }, FADE_MS + 20);
    }, remaining);
  }

  document.addEventListener("astro:page-load", revealAfterRise);
</script>
