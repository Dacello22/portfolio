---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import { SITE_TITLE, SITE_DESCRIPTION, SITE_URL, AUTHOR, ROLE, SOCIALS } from "../consts";

interface Props {
  title: string;
  description?: string;
  image?: string;
  noScroll?: boolean;
}

const { title, description = SITE_DESCRIPTION, image, noScroll = false } = Astro.props;
const pageTitle = title === SITE_TITLE ? title : `${title} | ${SITE_TITLE}`;
const canonicalURL = new URL(Astro.url.pathname, SITE_URL).toString();
const imageURL = image ? new URL(image, SITE_URL).toString() : undefined;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: AUTHOR,
  jobTitle: ROLE,
  url: SITE_URL,
  sameAs: SOCIALS.filter((s) => s.href.startsWith("http")).map((s) => s.href),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title={SITE_TITLE} href="/rss.xml" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    {imageURL && <meta property="og:image" content={imageURL} />}
    <meta name="twitter:card" content={imageURL ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    {imageURL && <meta name="twitter:image" content={imageURL} />}

    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
    <ClientRouter />
  </head>
  <body class:list={[{ "no-scroll": noScroll }]}>
    <svg style="position: absolute; width: 0; height: 0; overflow: hidden" aria-hidden="true">
      <defs>
        <symbol id="cyber-star" viewBox="0 0 24 24">
          <path d="M22,12 13.556,13.556 12,22 10.444,13.556 2,12 10.444,10.444 12,2 13.556,10.444Z" />
        </symbol>
        <symbol id="home-icon" viewBox="0 0 24 24">
          <path
            fill="none"
            stroke="currentColor"
            stroke-width="1.7"
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M3.5 10.5 12 3.5l8.5 7M5.5 9.5V20h13V9.5M9.5 20v-6h5v6"
          />
        </symbol>
      </defs>
    </svg>
    <header class="site-header">
      <div class="container">
        <nav>
          <a class="brand" href="/" aria-label={`${SITE_TITLE} — Home`}>
            <svg><use href="#home-icon" /></svg>
          </a>
          <div class="links">
            <a href="/blog">Blog</a>
            <a href="/contact">Contact</a>
          </div>
        </nav>
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
  </body>
</html>

<script>
  // Clicking a nav link for the page you're already on still made
  // Astro re-run the transition/page-load lifecycle for no reason —
  // skip the navigation entirely when the link points at the current
  // page.
  function initNavGuard() {
    if (document.body.dataset.navGuardBound === "true") return;
    document.body.dataset.navGuardBound = "true";

    const normalize = (path: string) => path.replace(/\/+$/, "") || "/";

    // Capture phase + stopImmediatePropagation: Astro's ClientRouter
    // also listens for link clicks on document (bubble phase) and
    // kicks off its transition/remount independently of whether this
    // event's default action gets prevented later. Running in the
    // capture phase means we see the click before that listener does,
    // and stopping propagation here keeps it from ever reaching Astro
    // at all — otherwise a same-page click still replayed the full
    // page transition (visible flash, animations like the hero ring
    // restarting from scratch).
    document.addEventListener(
      "click",
      (e) => {
        const link = (e.target as HTMLElement).closest("a");
        if (!link || !link.closest(".site-header")) return;

        const href = link.getAttribute("href");
        if (!href || href.startsWith("http") || href.startsWith("#")) return;

        const targetPath = normalize(new URL(href, location.origin).pathname);
        const currentPath = normalize(location.pathname);

        if (targetPath === currentPath) {
          e.preventDefault();
          e.stopImmediatePropagation();
        }
      },
      { capture: true }
    );
  }

  document.addEventListener("astro:page-load", initNavGuard);
</script>
