---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import { SITE_TITLE, SITE_DESCRIPTION, SITE_URL, AUTHOR, ROLE, SOCIALS } from "../consts";

interface Props {
  title: string;
  description?: string;
  image?: string;
  noScroll?: boolean;
}

const { title, description = SITE_DESCRIPTION, image, noScroll = false } = Astro.props;
const pageTitle = title === SITE_TITLE ? title : `${title} | ${SITE_TITLE}`;
const canonicalURL = new URL(Astro.url.pathname, SITE_URL).toString();
const imageURL = image ? new URL(image, SITE_URL).toString() : undefined;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: AUTHOR,
  jobTitle: ROLE,
  url: SITE_URL,
  sameAs: SOCIALS.filter((s) => s.href.startsWith("http")).map((s) => s.href),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title={SITE_TITLE} href="/rss.xml" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    {imageURL && <meta property="og:image" content={imageURL} />}
    <meta name="twitter:card" content={imageURL ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    {imageURL && <meta name="twitter:image" content={imageURL} />}

    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
    <ClientRouter />
  </head>
  <body class:list={[{ "no-scroll": noScroll }]}>
    <svg style="position: absolute; width: 0; height: 0; overflow: hidden" aria-hidden="true">
      <defs>
        <symbol id="cyber-star" viewBox="0 0 24 24">
          <path d="M22,12 13.556,13.556 12,22 10.444,13.556 2,12 10.444,10.444 12,2 13.556,10.444Z" />
        </symbol>
        <symbol id="sound-on" viewBox="0 0 24 24">
          <path
            fill="none"
            stroke="currentColor"
            stroke-width="1.6"
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M3 9.5v5h3.5L11 18V6L6.5 9.5H3Z"
          />
          <path
            fill="none"
            stroke="currentColor"
            stroke-width="1.6"
            stroke-linecap="round"
            d="M15.5 9a3.5 3.5 0 0 1 0 6M18 6.5a7 7 0 0 1 0 11"
          />
        </symbol>
        <symbol id="sound-off" viewBox="0 0 24 24">
          <path
            fill="none"
            stroke="currentColor"
            stroke-width="1.6"
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M3 9.5v5h3.5L11 18V6L6.5 9.5H3Z"
          />
          <path fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" d="M15.5 9.5 20 14M20 9.5l-4.5 4.5" />
        </symbol>
      </defs>
    </svg>
    <header class="site-header">
      <div class="container">
        <nav>
          <a class="brand" href="/">{SITE_TITLE}</a>
          <div class="links">
            <a href="/blog">Blog</a>
            <a href="/about">About</a>
            <a href="/resume">Resume</a>
            <a href="/contact">Contact</a>
          </div>
        </nav>
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
    <button class="sound-mute-btn" id="sound-mute-btn" type="button" aria-label="Mute hover sounds" aria-pressed="false">
      <svg><use href="#sound-on" /></svg>
    </button>
  </body>
</html>

<script>
  function initHoverSound() {
    const muteBtn = document.getElementById("sound-mute-btn");
    if (!muteBtn || muteBtn.dataset.bound === "true") return;
    muteBtn.dataset.bound = "true";

    const MUTE_KEY = "site-muted";
    let muted = localStorage.getItem(MUTE_KEY) === "true";
    let audioCtx: AudioContext | null = null;

    const iconUse = muteBtn.querySelector("use");
    const updateIcon = () => {
      iconUse?.setAttribute("href", muted ? "#sound-off" : "#sound-on");
      muteBtn!.setAttribute("aria-pressed", String(muted));
    };
    updateIcon();

    const playDeepHover = () => {
      if (muted) return;
      if (!audioCtx) {
        const Ctor = window.AudioContext || (window as any).webkitAudioContext;
        audioCtx = new Ctor();
      }
      if (audioCtx.state === "suspended") audioCtx.resume();

      const now = audioCtx.currentTime;
      const osc = audioCtx.createOscillator();
      const gain = audioCtx.createGain();
      osc.type = "sine";
      osc.frequency.setValueAtTime(95, now);
      osc.frequency.exponentialRampToValueAtTime(50, now + 0.18);
      gain.gain.setValueAtTime(0.0001, now);
      gain.gain.exponentialRampToValueAtTime(0.32, now + 0.015);
      gain.gain.exponentialRampToValueAtTime(0.0001, now + 0.22);
      osc.connect(gain).connect(audioCtx.destination);
      osc.start(now);
      osc.stop(now + 0.25);
    };

    // Delegated "mouseenter" via mouseover + relatedTarget check, so it
    // works for cards rendered after this script runs (no per-card
    // binding needed) and fires once per genuine entry, not on every
    // child mousemove.
    document.addEventListener("mouseover", (e) => {
      const target = e.target as HTMLElement;
      const card = target.closest(".blog-post-card, .carousel-card:not(.placeholder)");
      if (!card) return;
      const from = e.relatedTarget as Node | null;
      if (from && card.contains(from)) return;
      playDeepHover();
    });

    muteBtn.addEventListener("click", () => {
      muted = !muted;
      localStorage.setItem(MUTE_KEY, String(muted));
      updateIcon();
    });
  }

  document.addEventListener("astro:page-load", initHoverSound);
</script>
