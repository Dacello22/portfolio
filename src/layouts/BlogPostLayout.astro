---
import BaseLayout from "./BaseLayout.astro";
import { r2Url } from "../lib/r2";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
  heroImage?: string;
}

const { title, description, pubDate, updatedDate, tags = [], heroImage } = Astro.props;

const dateFmt = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
---

<BaseLayout title={title} description={description}>
  <article>
    {heroImage && <img src={r2Url(heroImage)} alt={title} loading="lazy" decoding="async" />}
    <p class="muted" style="margin-top: 1rem;">
      {dateFmt(pubDate)}
      {updatedDate && <> &middot; updated {dateFmt(updatedDate)}</>}
    </p>
    <h1>{title}</h1>
    {tags.length > 0 && (
      <p>
        {tags.map((t) => <span class="tag">{t}</span>)}
      </p>
    )}
    <slot />
  </article>
</BaseLayout>
