---
import BaseLayout from "./BaseLayout.astro";
import { r2Url } from "../lib/r2";
import type { MarkdownHeading } from "astro";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
  heroImage?: string;
  readingTime?: number;
  headings?: MarkdownHeading[];
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  tags = [],
  heroImage,
  readingTime,
  headings = [],
} = Astro.props;
const heroImageURL = heroImage ? r2Url(heroImage) : undefined;

const dateFmt = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
---

<BaseLayout title={title} description={description} image={heroImageURL}>
  <div class="reading-progress" id="reading-progress"></div>

  {headings.length > 1 && (
    <aside class="post-toc-wrap">
      <nav class="post-toc" aria-label="Table of contents">
        <p class="post-toc-title">On this page</p>
        <ul>
          {headings.map((h) => (
            <li class:list={[`post-toc-depth-${h.depth}`]}>
              <a href={`#${h.slug}`}>{h.text}</a>
            </li>
          ))}
        </ul>
      </nav>
    </aside>
  )}

  <article>
    <header class="post-header" class:list={[{ "post-header-with-image": heroImageURL }]}>
      <div class="post-header-text">
        <p class="muted">
          {dateFmt(pubDate)}
          {updatedDate && <> &middot; updated {dateFmt(updatedDate)}</>}
          {readingTime && <> &middot; {readingTime} min read</>}
        </p>
        <h1>{title}</h1>
        {tags.length > 0 && (
          <p class="card-tags">
            {tags.map((t) => <span class="tag">{t}</span>)}
          </p>
        )}
      </div>
      {heroImageURL && <img class="post-header-image" src={heroImageURL} alt={title} loading="lazy" decoding="async" />}
    </header>

    <div class="post-content">
      <slot />
    </div>
  </article>
  <button class="back-to-top" id="back-to-top" aria-label="Back to top" type="button">&uarr;</button>
</BaseLayout>

<script>
  type TocItem = { link: HTMLAnchorElement; el: HTMLElement };

  function initPostExtras() {
    const progress = document.getElementById("reading-progress");
    const backToTop = document.getElementById("back-to-top");
    const tocLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>(".post-toc a"));
    if (!progress || progress.dataset.bound === "true") return;
    progress.dataset.bound = "true";

    // How far below the viewport top a heading should land. Clears the
    // sticky header and gives a little breathing room, and it's the
    // exact same number used for click-scroll and scrollspy so the
    // active item always matches where a click lands.
    const SCROLL_OFFSET = 90;

    const items: TocItem[] = tocLinks
      .map((link): TocItem | null => {
        const id = decodeURIComponent(link.hash.slice(1));
        const el = document.getElementById(id);
        return el ? { link, el } : null;
      })
      .filter((it): it is TocItem => it !== null);

    let activeLink: HTMLAnchorElement | null = null;
    const setActive = (link: HTMLAnchorElement | null) => {
      if (link === activeLink) return;
      activeLink?.classList.remove("active");
      link?.classList.add("active");
      activeLink = link;
    };

    // Current section = the last heading whose top has scrolled above
    // the offset line. It stays highlighted across the whole section,
    // not just while the heading itself is near the top.
    const updateSpy = () => {
      let current: HTMLAnchorElement | null = null;
      for (const it of items) {
        if (it.el.getBoundingClientRect().top - SCROLL_OFFSET <= 1) current = it.link;
        else break;
      }
      setActive(current);
    };

    // While a click-initiated smooth scroll is animating, freeze the
    // spy so it doesn't flicker through intermediate headings on the
    // way to the target.
    let suppressSpyUntil = 0;
    let ticking = false;
    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        const doc = document.documentElement;
        const max = doc.scrollHeight - doc.clientHeight;
        progress.style.width = `${max > 0 ? (window.scrollY / max) * 100 : 0}%`;
        backToTop?.classList.toggle("visible", window.scrollY > 400);
        if (items.length && Date.now() >= suppressSpyUntil) updateSpy();
        ticking = false;
      });
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();

    backToTop?.addEventListener("click", () => window.scrollTo({ top: 0, behavior: "smooth" }));

    for (const it of items) {
      it.link.addEventListener("click", (e) => {
        e.preventDefault();
        const top = it.el.getBoundingClientRect().top + window.scrollY - SCROLL_OFFSET;
        suppressSpyUntil = Date.now() + 700;
        setActive(it.link);
        window.scrollTo({ top, behavior: "smooth" });
        history.replaceState(null, "", it.link.hash);
      });
    }
  }

  document.addEventListener("astro:page-load", initPostExtras);
</script>
