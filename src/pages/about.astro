---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SKILLS } from "../consts";
---

<BaseLayout title="About" description="About William Lunsford">
  <h1>About</h1>
  <p>
    Self-taught game developer focused on gameplay programming in Unreal Engine with C++.
  </p>

  <h2>Skills &amp; Tools</h2>
  <ul>
    {SKILLS.map((group) => (
      <li>{group.category}: {group.items.join(", ")}</li>
    ))}
  </ul>
</BaseLayout>
