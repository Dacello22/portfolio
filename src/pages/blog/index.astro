---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { r2Url } from "../../lib/r2";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const byYear = new Map<number, typeof posts>();
for (const post of posts) {
  const year = post.data.pubDate.getFullYear();
  if (!byYear.has(year)) byYear.set(year, []);
  byYear.get(year)!.push(post);
}
const years = [...byYear.keys()].sort((a, b) => b - a);

const allTags = [...new Set(posts.flatMap((p) => p.data.tags))].sort();
---

<BaseLayout title="Blog" description="Blog posts by William Lunsford">
  <h1 class="page-title">Blog</h1>

  <div class="blog-filters">
    <input
      type="search"
      id="blog-search"
      class="blog-search-input"
      placeholder="Search posts… (title, description, tags)"
      aria-label="Search posts"
    />
    <select id="blog-year-filter" class="blog-select" aria-label="Filter by year">
      <option value="">All years</option>
      {years.map((y) => <option value={y}>{y}</option>)}
    </select>

    {allTags.length > 0 && (
      <div class="tag-filter">
        <button
          type="button"
          id="tag-filter-toggle"
          class="tag-filter-toggle"
          aria-expanded="false"
          aria-controls="tag-filter-popover"
        >
          <span id="tag-filter-label">Tags</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m6 9 6 6 6-6" />
          </svg>
        </button>
        <button type="button" id="tag-filter-all" class="tag-filter-all-btn">All</button>

        <div class="tag-filter-popover" id="tag-filter-popover" hidden>
          <div class="tag-filter-popover-header">
            <span>Filter by tag</span>
            <button type="button" id="tag-filter-clear">Clear</button>
          </div>
          <div class="tag-filter-options">
            {allTags.map((t) => (
              <label class="tag-checkbox">
                <input type="checkbox" value={t} />
                <span>{t}</span>
              </label>
            ))}
          </div>
        </div>
      </div>
    )}
  </div>

  <p class="muted" id="blog-empty" style="display:none;">No posts match your search.</p>

  {years.map((year) => (
    <section class="blog-year-group" data-year={year}>
      <h2 class="year-heading">{year}</h2>
      <div class="grid">
        {byYear.get(year)!.map((post) => (
          <a
            class="card blog-post-card"
            href={`/blog/${post.slug}/`}
            data-title={post.data.title.toLowerCase()}
            data-description={post.data.description.toLowerCase()}
            data-tags={post.data.tags.join(",").toLowerCase()}
            data-year={post.data.pubDate.getFullYear()}
          >
            {post.data.heroImage && (
              <img src={r2Url(post.data.heroImage)} alt={post.data.title} loading="lazy" decoding="async" />
            )}
            <p class="muted">
              {post.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
            </p>
            <h3>{post.data.title}</h3>
            <p class="muted">{post.data.excerpt ?? post.data.description}</p>
            {post.data.tags.length > 0 && (
              <p class="card-tags">
                {post.data.tags.map((t) => <span class="tag">{t}</span>)}
              </p>
            )}
          </a>
        ))}
      </div>
    </section>
  ))}
</BaseLayout>

<script>
  function initBlogFilters() {
    const search = document.getElementById("blog-search") as HTMLInputElement | null;
    if (!search || search.dataset.bound === "true") return;
    search.dataset.bound = "true";

    const yearSelect = document.getElementById("blog-year-filter") as HTMLSelectElement | null;
    const groups = Array.from(document.querySelectorAll<HTMLElement>(".blog-year-group"));
    const emptyMsg = document.getElementById("blog-empty");
    const tagToggle = document.getElementById("tag-filter-toggle") as HTMLButtonElement | null;
    const tagAllBtn = document.getElementById("tag-filter-all");
    const tagClearBtn = document.getElementById("tag-filter-clear");
    const tagPopover = document.getElementById("tag-filter-popover");
    const tagLabel = document.getElementById("tag-filter-label");
    const tagCheckboxes = Array.from(document.querySelectorAll<HTMLInputElement>(".tag-checkbox input"));
    if (!yearSelect || !emptyMsg) return;

    function selectedTags(): string[] {
      return tagCheckboxes.filter((cb) => cb.checked).map((cb) => cb.value.toLowerCase());
    }

    function updateTagLabel() {
      const n = selectedTags().length;
      if (tagLabel) tagLabel.textContent = n > 0 ? `Tags (${n})` : "Tags";
      tagToggle?.classList.toggle("active", n > 0);
    }

    function matchesQuery(card: HTMLElement, tokens: string[]) {
      if (tokens.length === 0) return true;
      const title = card.dataset.title ?? "";
      const description = card.dataset.description ?? "";
      const tags = card.dataset.tags ?? "";
      const tagList = tags.split(",").filter(Boolean);
      const haystack = `${title} ${description} ${tags}`;
      return tokens.every((t) => haystack.includes(t) || tagList.includes(t));
    }

    function applyFilters() {
      const query = search!.value.trim().toLowerCase();
      const tokens = query.length ? query.split(/\s+/) : [];
      const year = yearSelect!.value;
      const tags = selectedTags();

      let anyVisible = false;

      groups.forEach((group) => {
        let groupHasVisible = false;
        group.querySelectorAll<HTMLElement>(".blog-post-card").forEach((card) => {
          const tagList = (card.dataset.tags ?? "").split(",").filter(Boolean);
          const tagOk = tags.length === 0 || tags.some((t) => tagList.includes(t));
          const yearOk = !year || card.dataset.year === year;
          const queryOk = matchesQuery(card, tokens);
          const visible = tagOk && yearOk && queryOk;
          card.style.display = visible ? "" : "none";
          if (visible) groupHasVisible = true;
        });
        group.style.display = groupHasVisible ? "" : "none";
        if (groupHasVisible) anyVisible = true;
      });

      emptyMsg!.style.display = anyVisible ? "none" : "";
    }

    function closePopover() {
      tagPopover?.setAttribute("hidden", "");
      tagToggle?.setAttribute("aria-expanded", "false");
    }

    function openPopover() {
      tagPopover?.removeAttribute("hidden");
      tagToggle?.setAttribute("aria-expanded", "true");
    }

    search.addEventListener("input", applyFilters);
    yearSelect.addEventListener("change", applyFilters);

    tagToggle?.addEventListener("click", () => {
      if (tagPopover?.hasAttribute("hidden")) openPopover();
      else closePopover();
    });

    document.addEventListener("click", (e) => {
      if (!tagPopover || tagPopover.hasAttribute("hidden")) return;
      const target = e.target as Node;
      if (!tagPopover.contains(target) && target !== tagToggle && !tagToggle?.contains(target)) {
        closePopover();
      }
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closePopover();
    });

    tagCheckboxes.forEach((cb) => {
      cb.addEventListener("change", () => {
        updateTagLabel();
        applyFilters();
      });
    });

    tagClearBtn?.addEventListener("click", () => {
      tagCheckboxes.forEach((cb) => (cb.checked = false));
      updateTagLabel();
      applyFilters();
    });

    tagAllBtn?.addEventListener("click", () => {
      tagCheckboxes.forEach((cb) => (cb.checked = false));
      updateTagLabel();
      closePopover();
      applyFilters();
    });
  }

  document.addEventListener("astro:page-load", initBlogFilters);
</script>
