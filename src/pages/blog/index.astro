---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="Blog" description="Blog posts by William Lunsford">
  <h1>Blog</h1>
  <div class="grid">
    {posts.map((post) => (
      <div class="card">
        <p class="muted">{post.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}</p>
        <h3><a href={`/blog/${post.slug}/`}>{post.data.title}</a></h3>
        <p class="muted">{post.data.description}</p>
      </div>
    ))}
  </div>
</BaseLayout>
