---
import fs from "node:fs";
import path from "node:path";
import BaseLayout from "../layouts/BaseLayout.astro";
import { AUTHOR, ROLE, ARTSTATION_URL, SOCIALS, SKILLS, FAVORITE_GENRES } from "../consts";

const hasResume = fs.existsSync(path.join(process.cwd(), "public", "resume.pdf"));

const icons: Record<string, string> = {
  Email: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6.75A2.25 2.25 0 0 1 5.25 4.5h13.5A2.25 2.25 0 0 1 21 6.75v10.5A2.25 2.25 0 0 1 18.75 19.5H5.25A2.25 2.25 0 0 1 3 17.25V6.75Z"/><path d="m3.5 7 7.59 6.13a1.5 1.5 0 0 0 1.82 0L20.5 7"/></svg>`,
  LinkedIn: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M4.98 3.5a2.5 2.5 0 1 0 .02 5 2.5 2.5 0 0 0-.02-5ZM3 9h4v12H3V9Zm6.5 0h3.8v1.7h.1c.5-.9 1.8-1.9 3.7-1.9 4 0 4.7 2.6 4.7 6V21h-4v-5.3c0-1.3 0-3-1.8-3s-2.1 1.4-2.1 2.9V21h-4V9Z"/></svg>`,
  X: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.24 3h2.86l-6.25 7.14L22.5 21h-6.1l-4.78-6.25L5.6 21H2.74l6.7-7.65L2 3h6.25l4.32 5.72L18.24 3Zm-2.13 16.2h1.58L7.97 4.7H6.28l9.83 14.5Z"/></svg>`,
  GitHub: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.58 2 12.25c0 4.5 2.87 8.32 6.84 9.67.5.1.68-.22.68-.49v-1.91c-2.78.62-3.37-1.36-3.37-1.36-.46-1.18-1.11-1.5-1.11-1.5-.91-.64.07-.63.07-.63 1 .07 1.53 1.05 1.53 1.05.89 1.56 2.34 1.11 2.91.85.09-.66.35-1.11.63-1.37-2.22-.26-4.56-1.13-4.56-5.02 0-1.11.39-2.02 1.03-2.73-.1-.26-.45-1.3.1-2.71 0 0 .84-.27 2.75 1.04a9.4 9.4 0 0 1 5 0c1.9-1.31 2.75-1.04 2.75-1.04.55 1.41.2 2.45.1 2.71.64.71 1.03 1.62 1.03 2.73 0 3.9-2.35 4.76-4.58 5.01.36.32.68.94.68 1.9v2.82c0 .27.18.6.69.49A10.02 10.02 0 0 0 22 12.25C22 6.58 17.52 2 12 2Z"/></svg>`,
  YouTube: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M22 12s0-3.07-.39-4.53a3.02 3.02 0 0 0-2.12-2.13C17.96 5 12 5 12 5s-5.96 0-7.49.34A3.02 3.02 0 0 0 2.39 7.47C2 8.93 2 12 2 12s0 3.07.39 4.53a3.02 3.02 0 0 0 2.12 2.13C5.96 19 12 19 12 19s5.96 0 7.49-.34a3.02 3.02 0 0 0 2.12-2.13C22 15.07 22 12 22 12Z"/><path fill="#0c0a08" d="M10 15.2 15.5 12 10 8.8v6.4Z"/></svg>`,
  ArtStation: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M0 17.72l2.06 3.59A1.5 1.5 0 0 0 3.38 22h12.49l-2.5-4.28H0ZM24 16.86c0-.31-.09-.62-.26-.89L16.5 3.33a1.5 1.5 0 0 0-1.3-.74h-4.1l11.36 19.46 1.27-2.18c.18-.32.27-.47.27-.86v-2.15ZM12.4 12.5 6.9 3.04 1.4 12.5h11Z"/></svg>`,
};

// Reach-me methods (direct contact) vs. profile links (browse my work).
const reachMethods = SOCIALS.filter((s) => ["Email", "LinkedIn", "X"].includes(s.label));
const profileLinks = [
  { label: "ArtStation", href: ARTSTATION_URL, handle: "Art & portfolio pieces" },
  ...SOCIALS.filter((s) => ["GitHub", "YouTube"].includes(s.label)),
];
---

<BaseLayout title="Contact" description={`About, links, and contact for ${AUTHOR}.`}>
  <h1 class="page-title">Contact</h1>

  <!-- About -->
  <section class="section">
    <h2 class="section-title">About Me</h2>
    <p>
      Self-taught game developer since 2022, focused on gameplay programming in Unreal Engine with
      C++. I prefer and specialize in VR game development. I build for and around how people actually
      move and interact in a headset rather than porting flat-screen design onto it. I develop and
      test on a Meta Quest 3.
    </p>
    <p>
      Outside of VR-specific work, I'm generally building toward the kinds of games I play the most:
      MMORPGs, RTS, and adventure/action titles. That mix shows up in what I tend to build, which
      leans toward systems-heavy gameplay, persistent worlds, and strategic depth over quick arcade
      loops.
    </p>

    <h3 class="subsection-title">Favorite Genres</h3>
    <p class="tag-row">
      {FAVORITE_GENRES.map((g) => <span class="tag">{g}</span>)}
    </p>

    <h3 class="subsection-title">Skills &amp; Tools</h3>
    <ul class="skills-list">
      {SKILLS.map((group) => (
        <li><span class="skills-cat">{group.category}:</span> {group.items.join(", ")}</li>
      ))}
    </ul>
  </section>

  <!-- Resume + work links -->
  <section class="section">
    <h2 class="section-title">Resume &amp; Work</h2>

    <div class="card resume-header">
      <div>
        <p class="resume-name">{AUTHOR}</p>
        <p class="muted">{ROLE}</p>
      </div>
      {hasResume ? (
        <a class="btn-primary" href="/resume.pdf" download>Download PDF</a>
      ) : (
        <span class="btn-primary disabled">PDF coming soon</span>
      )}
    </div>

    <div class="link-cards">
      {profileLinks.map((s) => (
        <a class="card link-card" href={s.href} target="_blank" rel="noopener">
          <span class="contact-icon" set:html={icons[s.label]} />
          <span class="link-card-text">
            <span class="contact-label">{s.label}</span>
            <span class="contact-handle muted">{s.handle}</span>
          </span>
        </a>
      ))}
    </div>
  </section>

  <!-- Reach me -->
  <section class="section">
    <h2 class="section-title">Reach Me</h2>
    <div class="grid contact-grid">
      {reachMethods.map((s) => (
        <a
          class="card contact-card"
          href={s.href}
          target={s.href.startsWith("http") ? "_blank" : undefined}
          rel="noopener"
        >
          <span class="contact-icon" set:html={icons[s.label]} />
          <span class="link-card-text">
            <span class="contact-label">{s.label}</span>
            <span class="contact-handle muted">{s.handle}</span>
          </span>
        </a>
      ))}
    </div>

    <div class="card contact-hours">
      <p class="contact-label">Preferred Hours</p>
      <p class="muted">
        I'm based in the Eastern Time zone (EST/EDT). That's when I'm quickest to respond.
      </p>
    </div>
  </section>
</BaseLayout>
