---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SOCIALS } from "../consts";
---

<BaseLayout title="Contact" description="Contact William Lunsford">
  <h1>Contact</h1>
  <ul>
    {SOCIALS.map((l) => (
      <li><a href={l.href} target={l.href.startsWith("http") ? "_blank" : undefined} rel="noopener">{l.label}</a></li>
    ))}
  </ul>
</BaseLayout>
