};
---

<BaseLayout title="Contact" description="Contact William Lunsford">
  <h1 class="page-title">Contact</h1>
  <div class="grid contact-grid">
    {SOCIALS.map((s) => (
      <a
        class="card contact-card"
        href={s.href}
        target={s.href.startsWith("http") ? "_blank" : undefined}
        rel="noopener"
      >
        <span class="contact-icon" set:html={icons[s.label]} />
        <span>
          <span class="contact-label">{s.label}</span>
          <span class="contact-handle muted">{s.handle}</span>
        </span>
      </a>
    ))}
  </div>
</BaseLayout>
