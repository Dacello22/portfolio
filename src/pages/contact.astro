  X: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.24 3h2.86l-6.25 7.14L22.5 21h-6.1l-4.78-6.25L5.6 21H2.74l6.7-7.65L2 3h6.25l4.32 5.72L18.24 3Zm-2.13 16.2h1.58L7.97 4.7H6.28l9.83 14.5Z"/></svg>`,
