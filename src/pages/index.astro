---
import BaseLayout from "../layouts/BaseLayout.astro";
import { projects } from "../data/projects";

const featured = projects.slice(0, 3);
---

<BaseLayout title="William Lunsford">
  <section style="padding-bottom: 2.5rem; border-bottom: 1px solid var(--border);">
    <h1 style="font-size: 3rem;">William Lunsford</h1>
    <p style="color: var(--accent-soft); margin-top: 0.5rem; font-size: 1.1rem;">Game Developer</p>
    <p class="muted" style="margin-top: 0.75rem; max-width: 36rem;">Building things, breaking things, writing about both.</p>
  </section>

  <section style="margin-top: 2.5rem;">
    <h2>Featured Projects</h2>
    <div class="grid">
      {featured.map((p) => (
        <div class="card">
          <h3>{p.title}</h3>
          <p class="muted">{p.description}</p>
          <p>
            {p.tags.map((t) => <span class="tag">{t}</span>)}
          </p>
          {p.link && <a href={p.link}>View &rarr;</a>}
        </div>
      ))}
    </div>
    <p style="margin-top: 1rem;"><a href="/projects">See all projects &rarr;</a></p>
  </section>
</BaseLayout>
