---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { AUTHOR, ROLE } from "../consts";

const featuredPosts = (await getCollection("blog", ({ data }) => !data.draft && data.featured)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const PLACEHOLDER_SLOTS = Math.max(0, 3 - featuredPosts.length);

// Ring of sharp stars encircling the name, each rotated so one of
// its points aims at the center (the star shape has 4-fold symmetry
// with a point at local "up" / -90deg, so rotating by angle-90
// aligns a point toward the ring center).
const RING_COUNT = 22;
const ringStars = Array.from({ length: RING_COUNT }, (_, i) => {
  const angle = (i / RING_COUNT) * Math.PI * 2;
  const angleDeg = (angle * 180) / Math.PI;
  const cx = 50;
  const cy = 50;
  const rx = 42; // base 38, scaled up ~10%
  const ry = 73; // base 58 -> stretched to 66 vertically, then scaled up ~10%
  const big = i % 3 === 0;
  return {
    x: cx + rx * Math.cos(angle),
    y: cy + ry * Math.sin(angle),
    size: big ? 30 + (i % 6) : 20 + (i % 6),
    opacity: big ? 0.95 : 0.7,
    rotate: Math.round(angleDeg - 90),
  };
});

---

<BaseLayout title={AUTHOR} noScroll>
  <section class="hero full-bleed" id="hero">
    <div class="hero-backdrop" aria-hidden="true">
      {ringStars.map((s) => (
        <svg
          class="hero-star"
          style={`left:${s.x}%; top:${s.y}%; width:${s.size}px; height:${s.size}px; opacity:${s.opacity}; transform:translate(-50%,-50%) rotate(${s.rotate}deg);`}
        >
          <use href="#cyber-star" />
        </svg>
      ))}
    </div>
    <div class="hero-inner">
      <p class="hero-eyebrow">Game Developer Portfolio</p>
      <h1 class="hero-name">{AUTHOR}</h1>
      <p class="hero-role">{ROLE}</p>
    </div>
  </section>

  <section class="featured-section full-bleed">
    <div class="featured-inner">
      <div class="featured-header">
        <h2>Featured Posts</h2>
      </div>
      <a class="featured-expand-arrow" href="/blog" id="featured-expand-arrow" aria-label="Open blog">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m6 9 6 6 6-6" />
        </svg>
      </a>
      <div class="carousel" id="featured-carousel">
        <div class="carousel-track">
          {featuredPosts.map((post) => (
            <a class="card carousel-card" href={`/blog/${post.slug}/`}>
              <p class="muted">
                {post.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
              </p>
              <h3>{post.data.title}</h3>
              <p class="muted">{post.data.description}</p>
            </a>
          ))}
          {Array.from({ length: PLACEHOLDER_SLOTS }).map(() => (
            <div class="card carousel-card placeholder">
              <p class="muted">More posts coming soon</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  function initFeaturedCarousel() {
    const carousel = document.getElementById("featured-carousel");
    if (!carousel || carousel.dataset.bound === "true") return;
    carousel.dataset.bound = "true";

    const maxScroll = () => carousel.scrollWidth - carousel.clientWidth;
    const clamp = (v: number) => Math.min(maxScroll(), Math.max(0, v));

    let target = carousel.scrollLeft;
    let rafId: number | null = null;

    const step = () => {
      const current = carousel.scrollLeft;
      const diff = target - current;
      if (Math.abs(diff) < 0.5) {
        carousel.scrollLeft = target;
        rafId = null;
        return;
      }
      carousel.scrollLeft = current + diff * 0.2;
      rafId = requestAnimationFrame(step);
    };

    const queueStep = () => {
      if (rafId === null) rafId = requestAnimationFrame(step);
    };

    carousel.addEventListener(
      "wheel",
      (e) => {
        if (Math.abs(e.deltaY) <= Math.abs(e.deltaX)) return;
        e.preventDefault();
        target = clamp(target - e.deltaY);
        queueStep();
      },
      { passive: false }
    );

    let isDragging = false;
    let startX = 0;
    let startScrollLeft = 0;
    let dragDistance = 0;

    carousel.addEventListener("pointerdown", (e) => {
      if (e.pointerType !== "mouse") return;
      isDragging = true;
      dragDistance = 0;
      target = carousel.scrollLeft;
      carousel.classList.add("dragging");
      startX = e.pageX;
      startScrollLeft = carousel.scrollLeft;
    });

    window.addEventListener("pointermove", (e) => {
      if (!isDragging) return;
      e.preventDefault();
      const dx = e.pageX - startX;
      dragDistance = Math.abs(dx);
      const next = clamp(startScrollLeft - dx);
      carousel.scrollLeft = next;
      target = next;
    });

    window.addEventListener("pointerup", () => {
      isDragging = false;
      carousel.classList.remove("dragging");
    });

    carousel.addEventListener("click", (e) => {
      if (dragDistance > 5) e.preventDefault();
    });
  }

  document.addEventListener("astro:page-load", initFeaturedCarousel);

  function initFeaturedExpandArrow() {
    const arrow = document.getElementById("featured-expand-arrow");
    const overlay = document.getElementById("page-rise-overlay");
    if (!arrow || arrow.dataset.bound === "true") return;
    arrow.dataset.bound = "true";

    arrow.addEventListener("click", () => {
      overlay?.classList.add("open");
    });
  }

  document.addEventListener("astro:page-load", initFeaturedExpandArrow);
</script>
