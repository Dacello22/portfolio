---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { AUTHOR, ROLE } from "../consts";

const featuredPosts = (await getCollection("blog", ({ data }) => !data.draft && data.featured)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const PLACEHOLDER_SLOTS = Math.max(0, 3 - featuredPosts.length);

// Ring of sharp stars encircling the name, each rotated so one of
// its points aims at the center (the star shape has 4-fold symmetry
// with a point at local "up" / -90deg, so rotating by angle-90
// aligns a point toward the ring center).
const RING_COUNT = 22;
const ringStars = Array.from({ length: RING_COUNT }, (_, i) => {
  const angle = (i / RING_COUNT) * Math.PI * 2;
  const angleDeg = (angle * 180) / Math.PI;
  const cx = 50;
  const cy = 50;
  const rx = 42; // base 38, scaled up ~10%
  const ry = 73; // base 58 -> stretched to 66 vertically, then scaled up ~10%
  const big = i % 3 === 0;
  return {
    x: cx + rx * Math.cos(angle),
    y: cy + ry * Math.sin(angle),
    size: big ? 30 + (i % 6) : 20 + (i % 6),
    opacity: big ? 0.95 : 0.7,
    rotate: Math.round(angleDeg - 90),
  };
});

// Cyber-sigilism crack streaks: irregular spiky bursts, like jagged
// veins/cracks. Hidden almost entirely in the dark backdrop; an
// amber glow follows the mouse and "lights up" the same shapes
// within a small radius (see .sigil-streaks-bright + the mask in
// global.css). Same shapes are rendered twice — once faint/static,
// once bright/masked — so the reveal lines up exactly.
function buildStreakPath() {
  const spikes = 7 + Math.floor(Math.random() * 4);
  const points: string[] = [];
  for (let i = 0; i < spikes; i++) {
    const angle = (i / spikes) * Math.PI * 2 + (Math.random() - 0.5) * 0.35;
    const outerR = 55 + Math.random() * 130;
    const innerR = 8 + Math.random() * 16;
    const innerAngle = angle + Math.PI / spikes;
    points.push(`${(Math.cos(angle) * outerR).toFixed(1)},${(Math.sin(angle) * outerR).toFixed(1)}`);
    points.push(`${(Math.cos(innerAngle) * innerR).toFixed(1)},${(Math.sin(innerAngle) * innerR).toFixed(1)}`);
  }
  return `M${points.join(" L")} Z`;
}

const streakShapes = [
  { x: 18, y: 30, scale: 1.1, rotate: 10 },
  { x: 78, y: 22, scale: 0.85, rotate: 140 },
  { x: 85, y: 72, scale: 1.3, rotate: 60 },
  { x: 12, y: 75, scale: 0.95, rotate: 250 },
  { x: 50, y: 88, scale: 0.7, rotate: 300 },
].map((s) => ({ ...s, path: buildStreakPath() }));
---

<BaseLayout title={AUTHOR} noScroll>
  <section class="hero full-bleed" id="hero">
    <div class="sigil-streaks" aria-hidden="true">
      {streakShapes.map((s) => (
        <svg viewBox="-200 -200 400 400" style={`left:${s.x}%; top:${s.y}%; width:${340 * s.scale}px; height:${340 * s.scale}px; transform:translate(-50%,-50%) rotate(${s.rotate}deg);`}>
          <path d={s.path} fill="currentColor" />
        </svg>
      ))}
    </div>
    <div class="sigil-glow" aria-hidden="true"></div>
    <div class="sigil-streaks-bright" aria-hidden="true">
      {streakShapes.map((s) => (
        <svg viewBox="-200 -200 400 400" style={`left:${s.x}%; top:${s.y}%; width:${340 * s.scale}px; height:${340 * s.scale}px; transform:translate(-50%,-50%) rotate(${s.rotate}deg);`}>
          <path d={s.path} fill="currentColor" />
        </svg>
      ))}
    </div>
    <div class="hero-backdrop" aria-hidden="true">
      {ringStars.map((s) => (
        <svg
          class="hero-star"
          style={`left:${s.x}%; top:${s.y}%; width:${s.size}px; height:${s.size}px; opacity:${s.opacity}; transform:translate(-50%,-50%) rotate(${s.rotate}deg);`}
        >
          <use href="#cyber-star" />
        </svg>
      ))}
    </div>
    <div class="hero-inner">
      <p class="hero-eyebrow">Game Developer Portfolio</p>
      <h1 class="hero-name">{AUTHOR}</h1>
      <p class="hero-role">{ROLE}</p>
    </div>
  </section>

  <section class="featured-section full-bleed">
    <div class="featured-inner">
      <div class="featured-header">
        <h2>Featured Posts</h2>
      </div>
      <div class="carousel" id="featured-carousel">
        <div class="carousel-track">
          {featuredPosts.map((post) => (
            <a class="card carousel-card" href={`/blog/${post.slug}/`}>
              <p class="muted">
                {post.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
              </p>
              <h3>{post.data.title}</h3>
              <p class="muted">{post.data.description}</p>
            </a>
          ))}
          {Array.from({ length: PLACEHOLDER_SLOTS }).map(() => (
            <div class="card carousel-card placeholder">
              <p class="muted">More posts coming soon</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  function initFeaturedCarousel() {
    const carousel = document.getElementById("featured-carousel");
    if (!carousel || carousel.dataset.bound === "true") return;
    carousel.dataset.bound = "true";

    const maxScroll = () => carousel.scrollWidth - carousel.clientWidth;
    const clamp = (v: number) => Math.min(maxScroll(), Math.max(0, v));

    let target = carousel.scrollLeft;
    let rafId: number | null = null;

    const step = () => {
      const current = carousel.scrollLeft;
      const diff = target - current;
      if (Math.abs(diff) < 0.5) {
        carousel.scrollLeft = target;
        rafId = null;
        return;
      }
      carousel.scrollLeft = current + diff * 0.2;
      rafId = requestAnimationFrame(step);
    };

    const queueStep = () => {
      if (rafId === null) rafId = requestAnimationFrame(step);
    };

    carousel.addEventListener(
      "wheel",
      (e) => {
        if (Math.abs(e.deltaY) <= Math.abs(e.deltaX)) return;
        e.preventDefault();
        target = clamp(target - e.deltaY);
        queueStep();
      },
      { passive: false }
    );

    let isDragging = false;
    let startX = 0;
    let startScrollLeft = 0;
    let dragDistance = 0;

    carousel.addEventListener("pointerdown", (e) => {
      if (e.pointerType !== "mouse") return;
      isDragging = true;
      dragDistance = 0;
      target = carousel.scrollLeft;
      carousel.classList.add("dragging");
      startX = e.pageX;
      startScrollLeft = carousel.scrollLeft;
    });

    window.addEventListener("pointermove", (e) => {
      if (!isDragging) return;
      e.preventDefault();
      const dx = e.pageX - startX;
      dragDistance = Math.abs(dx);
      const next = clamp(startScrollLeft - dx);
      carousel.scrollLeft = next;
      target = next;
    });

    window.addEventListener("pointerup", () => {
      isDragging = false;
      carousel.classList.remove("dragging");
    });

    carousel.addEventListener("click", (e) => {
      if (dragDistance > 5) e.preventDefault();
    });
  }

  document.addEventListener("astro:page-load", initFeaturedCarousel);

  function initSigilGlow() {
    const hero = document.getElementById("hero");
    if (!hero || hero.dataset.glowBound === "true") return;
    hero.dataset.glowBound = "true";

    const onMove = (e: PointerEvent) => {
      const rect = hero.getBoundingClientRect();
      hero.style.setProperty("--mx", `${e.clientX - rect.left}px`);
      hero.style.setProperty("--my", `${e.clientY - rect.top}px`);
    };
    hero.addEventListener("pointermove", onMove);
  }

  document.addEventListener("astro:page-load", initSigilGlow);
</script>
