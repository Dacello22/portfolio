---
import fs from "node:fs";
import path from "node:path";
import BaseLayout from "../layouts/BaseLayout.astro";
import { AUTHOR, ROLE, ARTSTATION_URL, SOCIALS } from "../consts";

const hasResume = fs.existsSync(path.join(process.cwd(), "public", "resume.pdf"));

const github = SOCIALS.find((s) => s.label === "GitHub");
const youtube = SOCIALS.find((s) => s.label === "YouTube");
---

<BaseLayout title="Resume" description={`${AUTHOR}'s resume`}>
  <h1 class="page-title">Resume</h1>

  <div class="card resume-header">
    <div>
      <p class="resume-name">{AUTHOR}</p>
      <p class="muted">{ROLE}</p>
    </div>
    {hasResume ? (
      <a class="btn-primary" href="/resume.pdf" download>Download PDF</a>
    ) : (
      <span class="btn-primary disabled">PDF coming soon</span>
    )}
  </div>

  <hr class="resume-divider" />

  <div class="resume-links-group">
    <a class="card resume-header resume-header-sm" href={ARTSTATION_URL} target="_blank" rel="noopener">
      <div>
        <p class="resume-name resume-name-sm">ArtStation</p>
        <p class="muted resume-subtext-sm">Art &amp; portfolio pieces</p>
      </div>
      <span class="btn-primary">View Profile</span>
    </a>

    {github && (
      <a class="card resume-header resume-header-sm" href={github.href} target="_blank" rel="noopener">
        <div>
          <p class="resume-name resume-name-sm">GitHub</p>
          <p class="muted resume-subtext-sm">Code &amp; repos — {github.handle}</p>
        </div>
        <span class="btn-primary">View Profile</span>
      </a>
    )}

    {youtube && (
      <a class="card resume-header resume-header-sm" href={youtube.href} target="_blank" rel="noopener">
        <div>
          <p class="resume-name resume-name-sm">YouTube</p>
          <p class="muted resume-subtext-sm">Devlogs &amp; gameplay — {youtube.handle}</p>
        </div>
        <span class="btn-primary">View Profile</span>
      </a>
    )}
  </div>
</BaseLayout>
