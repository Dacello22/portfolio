---
import fs from "node:fs";
import path from "node:path";
import BaseLayout from "../layouts/BaseLayout.astro";
import { AUTHOR, ROLE, ARTSTATION_URL } from "../consts";

const hasResume = fs.existsSync(path.join(process.cwd(), "public", "resume.pdf"));
---

<BaseLayout title="Resume" description={`${AUTHOR}'s resume`}>
  <h1 class="page-title">Resume</h1>

  <div class="card resume-header">
    <div>
      <p class="resume-name">{AUTHOR}</p>
      <p class="muted">{ROLE}</p>
    </div>
    {hasResume ? (
      <a class="btn-primary" href="/resume.pdf" download>Download PDF</a>
    ) : (
      <span class="btn-primary disabled">PDF coming soon</span>
    )}
  </div>

  <hr class="resume-divider" />

  <a class="card resume-header resume-header-sm" href={ARTSTATION_URL} target="_blank" rel="noopener">
    <div>
      <p class="resume-name resume-name-sm">ArtStation</p>
      <p class="muted resume-subtext-sm">Art &amp; portfolio pieces</p>
    </div>
    <span class="btn-primary">View Profile</span>
  </a>
</BaseLayout>
